# ─────────────────────────────────────────────────────────────
#  SISTEMA DENTAL — Variables de entorno
#  Copiar a .env.local y rellenar. NUNCA commitear .env.local.
# ─────────────────────────────────────────────────────────────

# URL pública del proyecto Supabase (segura para el cliente)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Anon key pública (segura para el cliente — protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# service_role — SOLO SERVIDOR. NUNCA con prefijo NEXT_PUBLIC_.
# Se usa exclusivamente en módulos con `import "server-only"`.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# URL canónica del sitio (para redirects de auth y metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
